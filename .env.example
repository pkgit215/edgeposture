# RuleIQ — required environment variables. Copy to `.env` and fill in.
# DO NOT commit `.env` (gitignored). DO NOT add real values here.

# ── Backend (FastAPI) ───────────────────────────────────────────────────────

# Mongo connection string (mongodb+srv://… or mongodb://…).
MONGODB_URI=

# OpenAI API key — used by the AI pipeline (Pass 1 + Pass 2). Format: sk-…
OPENAI_API_KEY=

# AWS region the audit pipeline operates in. Default: us-east-1.
AWS_REGION=us-east-1

# Customer-facing CloudFormation Quick-Create defaults. The customer
# `RuleIQAuditRole` trusts this account ID. Set to your real account ID
# locally / via Secrets Manager in production. Use the AWS-reserved
# placeholder 123456789012 in tests and docs.
RULEIQ_APP_RUNNER_ACCOUNT_ID=
RULEIQ_PUBLIC_TEMPLATES_BUCKET=

# Secret used to derive per-tenant ExternalId values (HMAC-SHA256 seed).
# Production: pull from AWS Secrets Manager. Local dev: any 64-char string.
EXTERNAL_ID_SECRET=

# Feature flags.
DEMO_MODE=true
RULEIQ_TESTING=0

# Path to the built Vite SPA (Dockerfile copies to /app/static).
RULEIQ_SPA_DIST=/app/static

# ── Frontend (Vite) ─────────────────────────────────────────────────────────

# Backend base URL. In dev: http://localhost:8001. In prod: same-origin
# (leave blank).
REACT_APP_BACKEND_URL=
